<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0" xsi:type="MailApp">
<!--  Basic metadata  -->
<Id>5d837f93-81c7-4009-a793-57c565fe4a0b</Id>
<Version>1.0.0.5</Version>
<ProviderName>NHIT Compliance</ProviderName>
<DefaultLocale>en-US</DefaultLocale>
<DisplayName DefaultValue="UPSI Compliance Guard"/>
<Description DefaultValue="Real-time threat detection for UPSI compliance in Outlook."/>
<IconUrl DefaultValue="https://aigoniyo.com/assets/icons/icon-80.png"/>
<HighResolutionIconUrl DefaultValue="https://aigoniyo.com/assets/icons/icon-80.png"/>
<SupportUrl DefaultValue="https://aigoniyo.com/support"/>
<AppDomains>
<AppDomain>https://aigoniyo.com</AppDomain>
</AppDomains>
<Hosts>
<Host Name="Mailbox"/>
</Hosts>
<!--  Minimum requirement for legacy Outlook clients  -->
<Requirements>
<Sets>
<Set Name="Mailbox" MinVersion="1.1"/>
</Sets>
</Requirements>
<!--  Legacy form factor (older Outlook clients)  -->
<FormSettings>
<Form xsi:type="ItemEdit">
<DesktopSettings>
<SourceLocation DefaultValue="https://aigoniyo.com/src/taskpane/taskpane.html"/>
</DesktopSettings>
</Form>
</FormSettings>
<Permissions>ReadWriteItem</Permissions>
<Rule xsi:type="RuleCollection" Mode="Or">
<Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit"/>
</Rule>
<DisableEntityHighlighting>false</DisableEntityHighlighting>
<!-- 
    VersionOverrides V1_0 wraps V1_1 so that:
      - V1_1-capable clients use the inner block (Shared Runtime + Events)
      - V1_0-capable clients fall back to the outer block (ribbon button only)
   -->
<VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
<VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.1" xsi:type="VersionOverridesV1_1">
<!-- 
        Mailbox 1.12 is required for:
          - OnNewMessageCompose event
          - OnMessageSend (Smart Alerts)
          - Shared Runtime
       -->
<Requirements>
<bt:Sets>
<bt:Set Name="Mailbox" MinVersion="1.12"/>
</bt:Sets>
</Requirements>
<Hosts>
<Host xsi:type="MailHost">
<!-- 
            SHARED RUNTIME
            ══════════════
            A single HTML runtime hosts BOTH the taskpane UI and the event
            handlers.  Outlook Web loads taskpane.html when any event fires;
            taskpane.html loads launchevents.js which registers the handlers
            via Office.actions.associate().

            The <Override type="javascript"> provides a pure-JS fallback for
            Outlook on Windows (which cannot run an HTML runtime for events).
           -->
<Runtimes>
<Runtime resid="Taskpane.Url" lifetime="long">
<Override type="javascript" resid="Events.Url"/>
</Runtime>
</Runtimes>
<DesktopFormFactor>
<!--  Ribbon button → opens taskpane  -->
<ExtensionPoint xsi:type="MessageComposeCommandSurface">
<OfficeTab id="TabDefault">
<Group id="msgComposeGroup">
<Label resid="GroupLabel"/>
<Control xsi:type="Button" id="TaskpaneButton">
<Label resid="TaskpaneBtnLabel"/>
<Supertip>
<Title resid="TaskpaneBtnSuperTipTitle"/>
<Description resid="TaskpaneBtnSuperTipDescription"/>
</Supertip>
<Icon>
<bt:Image size="16" resid="Icon.16x16"/>
<bt:Image size="32" resid="Icon.32x32"/>
<bt:Image size="80" resid="Icon.80x80"/>
</Icon>
<Action xsi:type="ShowTaskpane">
<SourceLocation resid="Taskpane.Url"/>
<SupportsPinning>true</SupportsPinning>
</Action>
</Control>
</Group>
</OfficeTab>
</ExtensionPoint>
<!-- 
              EVENT-BASED ACTIVATION
              ═══════════════════════
              SourceLocation MUST match the Runtime resid (Taskpane.Url) when
              using a Shared Runtime.  Do NOT point this at the JS file —
              that causes schema validation failures and installation errors.
             -->
<ExtensionPoint xsi:type="LaunchEvent">
<LaunchEvents>
<LaunchEvent Type="OnNewMessageCompose" FunctionName="onNewMessageComposeHandler"/>
<LaunchEvent Type="OnMessageSend" FunctionName="onMessageSendHandler" SendMode="SoftBlock"/>
</LaunchEvents>
<SourceLocation resid="Taskpane.Url"/>
</ExtensionPoint>
</DesktopFormFactor>
</Host>
</Hosts>
<!--  Resources  -->
<Resources>
<bt:Images>
<bt:Image id="Icon.16x16" DefaultValue="https://aigoniyo.com/assets/icons/icon-16.png"/>
<bt:Image id="Icon.32x32" DefaultValue="https://aigoniyo.com/assets/icons/icon-32.png"/>
<bt:Image id="Icon.80x80" DefaultValue="https://aigoniyo.com/assets/icons/icon-80.png"/>
</bt:Images>
<bt:Urls>
<!--  Shared Runtime HTML page (hosts taskpane UI + event handlers)  -->
<bt:Url id="Taskpane.Url" DefaultValue="https://aigoniyo.com/src/taskpane/taskpane.html"/>
<!--  Pure-JS fallback for Outlook on Windows desktop  -->
<bt:Url id="Events.Url" DefaultValue="https://aigoniyo.com/src/launchevents/launchevents.js"/>
</bt:Urls>
<bt:ShortStrings>
<bt:String id="GroupLabel" DefaultValue="UPSI Compliance"/>
<bt:String id="TaskpaneBtnLabel" DefaultValue="UPSI Guard"/>
<bt:String id="TaskpaneBtnSuperTipTitle" DefaultValue="UPSI Compliance Guard"/>
</bt:ShortStrings>
<bt:LongStrings>
<bt:String id="TaskpaneBtnSuperTipDescription" DefaultValue="Monitor this email for UPSI compliance violations in real time."/>
</bt:LongStrings>
</Resources>
</VersionOverrides>
</VersionOverrides>
</OfficeApp>